<?php
session_start();

// --- إعدادات لوحة التحكم ---
$admin_user = "Admin";
$admin_pass = "123456";
$settings_file = "settings.json";

// تحميل الإعدادات (الرابط والعنوان)
if (file_exists($settings_file)) {
    $settings = json_decode(file_get_contents($settings_file), true);
} else {
    $settings = ["url" => "https://example.com", "title" => "إعلان افتراضي"];
}

// تسجيل الدخول
if (isset($_POST['login'])) {
    if ($_POST['user'] == $admin_user && $_POST['pass'] == $admin_pass) {
        $_SESSION['admin_logged_in'] = true;
    }
}

// تسجيل الخروج
if (isset($_GET['logout'])) {
    session_destroy();
    header("Location: index.php");
}

// تحديث الإعدادات
if (isset($_POST['update_settings']) && isset($_SESSION['admin_logged_in'])) {
    $new_settings = ["url" => $_POST['site_url'], "title" => $_POST['site_title']];
    file_put_contents($settings_file, json_encode($new_settings));
    $settings = $new_settings;
    $msg = "تم التحديث بنجاح!";
}

// فحص هل الإعلان متاح للمستخدم (24 ساعة)
$is_locked = isset($_COOKIE['ad_lock']);
?>

