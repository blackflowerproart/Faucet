            <input type="text" name="site_title" placeholder="عنوان الإعلان" value="<?php echo $settings['title']; ?>">
            <input type="text" name="site_url" placeholder="رابط الموقع (EasyHits)" value="<?php echo $settings['url']; ?>">
            <button type="submit" name="update_settings" class="btn">حفظ التغييرات</button>
            <a href="?logout=1" style="color:red; display:block; margin-top:10px;">تسجيل خروج</a>
        </form>
        <?php if(isset($msg)) echo "<p style='color:green'>$msg</p>"; ?>
    <?php endif; ?>
</div>

<script>
function startAd() {
    // فتح رابط الإعلان في نافذة جديدة
    window.open("<?php echo $settings['url']; ?>", "_blank");
    
    document.getElementById('startBtn').style.display = 'none';
    document.getElementById('adArea').style.display = 'block';
    
    let timeLeft = 20;
    let countdown = setInterval(function() {
        timeLeft--;
        document.getElementById('seconds').innerText = timeLeft;
        
        if (timeLeft <= 0) {
            clearInterval(countdown);
            completeAd();
        }
    }, 1000);
}

function completeAd() {
    document.getElementById('adArea').style.display = 'none';
    document.getElementById('rewardArea').style.display = 'block';
    
    // إرسال طلب لتعيين الكوكي (قفل 24 ساعة)
    document.cookie = "ad_lock=1; max-age=" + (24 * 60 * 60) + "; path=/";
    
    // هنا يمكنك إضافة كود Ajax لإرسال الأرباح لقاعدة البيانات الخاصة بموقعك
    alert("تمت إضافة الأرباح إلى حسابك وقفل الإعلان لمدة 24 ساعة!");
    location.reload(); 
}
</script>

